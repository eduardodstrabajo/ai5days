#!/bin/bash
# Simple pre-commit hook to scan staged changes for common secret patterns.
# Install by running: npm run install:hooks

set -euo pipefail

# Patterns to detect (case-sensitive where appropriate)
patterns=(
  "GEMINI_API_KEY"
  "APP_API_KEY"
  "AIzaSy"
  "sk-"
  "ghp_"
  "BEGIN PRIVATE KEY"
  "PRIVATE KEY"
  "ACCESS_TOKEN"
  "SECRET_KEY"
  "SECRET="
  "password="
  "token:"
  "Bearer "
  "eyJ"
)

# Get list of staged files (name only)
staged_files=$(git diff --cached --name-only --diff-filter=ACM || true)

if [ -z "$staged_files" ]; then
  exit 0
fi

# Check each staged file content for patterns
found=0
for file in $staged_files; do
  # skip binary files
  if file --brief --mime-type "$file" 2>/dev/null | grep -qE '^(image|video|audio|application)'; then
    continue
  fi

  for p in "${patterns[@]}"; do
    if git show :"$file" 2>/dev/null | grep -nF -- "${p}" >/dev/null 2>&1; then
      echo "Potential secret detected in $file -> pattern: ${p}"
      git show :"$file" | grep -nF -- "${p}" | sed -n '1,5p'
      found=1
    fi
  done
done

if [ "$found" -eq 1 ]; then
  echo "\nERROR: Pre-commit check failed. Possible secrets detected in staged files."
  echo "If these are false positives, adjust .githooks/pre-commit or use git add -f to force commit (not recommended)."
  exit 1
fi

exit 0
