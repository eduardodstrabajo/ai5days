# Copy this file to .env.local (do NOT commit .env.local) and fill in secrets.
# Required environment variables:
# GEMINI_API_KEY: API key for the Gemini/GenAI provider (keep secret).
# APP_API_KEY: Shared server API key to authenticate clients (set in GitHub Secrets for production).
# ALLOWED_ORIGIN: Production origin (e.g., https://app.example.com) for CORS.
# NODE_ENV: development | production
# PORT: server port

GEMINI_API_KEY=
APP_API_KEY=
ALLOWED_ORIGIN=
NODE_ENV=development
PORT=3000
